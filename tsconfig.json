{
    "compilerOptions": {
          "target": "ES2022",
          "lib": ["ES2022", "DOM", "DOM.Iterable"],
          "module": "ESNext",
          "moduleResolution": "bundler",
          "jsx": "react-jsx",
          "strict": true,
          "skipLibCheck": true,
          "moduleDetection": "force",
          "allowImportingTsExtensions": true,
          "noEmit": true,
          "isolatedModules": true,
          "types": ["@cloudflare/workers-types"]
    },
    "include": ["src", "env.d.ts"]
}
